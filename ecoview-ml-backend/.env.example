# Google Gemini API key for the VLM Teacher model (obtain from Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key-here

# Allowed CORS origins (comma-separated, no trailing slashes)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173,http://127.0.0.1:5173,https://ecoview.vercel.app

# Port for FastAPI application (default: 8080)
PORT=8080

# Logging level for ONNX runtime (3 = severe warnings/errors only)
ORT_LOGGING_LEVEL=3
