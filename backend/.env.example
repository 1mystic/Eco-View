# Supabase PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECT-REF.supabase.co:5432/postgres

# Firebase Admin SDK — download from Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Cloudflare R2 — create bucket at dash.cloudflare.com → R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=ecoview-images
R2_PUBLIC_URL=https://pub-HASH.r2.dev

# Upstash Redis — create at upstash.com (free tier)
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

# App
ENVIRONMENT=development
MAX_IMAGE_SIZE_MB=10

# ML Backend Microservice
ML_BACKEND_URL=http://localhost:8080
